# Production environment variables
# Copy this to .env.production and fill in the values

# Server
PORT=8080
NODE_ENV=production

# JWT - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=printing_press
DB_USER=printing_user
DB_PASSWORD=change-this-strong-password

# Pricing (INR)
BW_PER_PAGE=2
COLOR_PER_PAGE=8
GST_PERCENT=18
